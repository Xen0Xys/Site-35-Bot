{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "sortTailwindcss": {},
    "trailingComma": "all",
    "tabWidth": 4,
    "semi": true,
    "singleQuote": false,
    "bracketSpacing": false,
    "bracketSameLine": true,
    "arrowParens": "always",
    "objectWrap": "preserve",
    "printWidth": 121,
    "sortPackageJson": false,
    "ignorePatterns": ["node_modules", "prisma/generated"],
    "endOfLine": "lf"
}
