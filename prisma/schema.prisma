generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

enum Units {
  SITE_SECURITY
  XI_8
  ALPHA_1

  @@map("units")
}

enum Ranks {
  CMD
  MJR
  CPT
  LTN
  S_LTN
  ADJ_C
  ADJ
  SGT_C
  SGT
  CPL_C
  CPL
  SDT_1C
  SDT_2C
  SDT_3C
  SDT
  CDT

  @@map("ranks")
}

enum Trainings {
  FIM
  FIM_INSTRUCTOR
  CQC
  CQC_INSTRUCTOR
  FIRST_AID
  FIRST_AID_INSTRUCTOR
  BREACHER
  GRENADE_LAUNCHER
  FLAMETHROWER
  ANTI_TANK
  ARTIFICIER
  SNIPER
  MACHINE_GUNNER
  MEDIC
  DRONE

  @@map("trainings")
}

enum MessageTypes {
  STATUS

  @@map("message_types")
}

enum Medals {
  CROSS_OF_TACTICAL_SUPREMACY

  @@map("medals")
}

model Users {
  id             BigInt          @id
  rank           Ranks
  name           String
  unit           Units?
  user_trainings UserTrainings[]
  user_medals    UserMedals[]
  created_at     DateTime        @default(now())
  updated_at     DateTime        @default(now()) @updatedAt

  @@map("users")
}

model UserTrainings {
  user_id    BigInt
  training   Trainings
  user       Users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime  @default(now())

  @@id([user_id, training])
  @@map("user_trainings")
}

model UserMedals {
  user_id    BigInt
  medal      Medals
  user       Users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@id([user_id, medal])
  @@map("user_medals")
}

model TrackedMessages {
  message_id BigInt
  channel_id BigInt
  type       MessageTypes
  created_at DateTime     @default(now())

  @@id([message_id, channel_id])
  @@map("tracked_messages")
}
